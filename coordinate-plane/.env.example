# Local: copy to .env.local  |  Vercel: Project → Settings → Environment Variables → redeploy
#
# Google OAuth: Authorized redirect URI must include your site origin (e.g. https://….vercel.app)
# — Instant sends that to Google. POST / is proxied to /api/instant-oauth-callback on Vercel.
# Test OAuth locally with: vercel dev

# Google Web Client ID (same value in Instant + Google Cloud). Required for the popup button; optional for redirect-only.
# VITE_GOOGLE_CLIENT_ID=71583658488-xxxx.apps.googleusercontent.com

# Instant app ID (OfficeManagement). Omit to use the default baked into js/db.js.
# VITE_INSTANT_APP_ID=893fc487-41f4-4370-a6e5-b25bff85fe99

# Only if your Instant Google client name differs from google-web
# VITE_INSTANT_GOOGLE_CLIENT_NAME=my-oauth-client-name

# Local-only: skip sign-in (never enable on Vercel Production)
# VITE_AUTH_DISABLED=true
